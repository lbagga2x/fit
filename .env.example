# Neon PostgreSQL — get from neon.tech dashboard
# "Pooled connection" string (for serverless/Vercel)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# "Direct connection" string (for migrations/seed)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
